modules = ["php-8.2", "nodejs-20", "web", "vue-node-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "start-prod.sh"]
build = ["bash", "build.sh"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.production]
APP_INSTALLED = "1"
APP_ENV = "prod"
TRUSTED_PROXIES = "0.0.0.0/0"
CORS_ALLOW_ORIGIN = '^https?://(.+\.replit\.dev|.+\.replit\.app|localhost|127\.0\.0\.1)(:[0-9]+)?$'
APP_LOCALE = "pt_BR"

[userenv.shared]
PHP_MEMORY_LIMIT = "512M"
COMPOSER_MEMORY_LIMIT = "-1"
PHPRC = "/home/runner/workspace/php.ini"
PHP_INI_SCAN_DIR = "/nix/store/8xs6a2mh8vhb0r5ds4wh5nm6a59x66z6-php-with-extensions-8.2.23/lib:/home/runner/workspace/config/php-cli"

[[ports]]
localPort = 5000
externalPort = 80

[objectStorage]
defaultBucketID = "replit-objstore-023be920-4f7f-4732-8f41-08729241e402"
