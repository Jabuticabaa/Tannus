{% extends 'base.html.twig' %}

{% block title %}Erro – Tannus AI{% endblock %}

{% block stylesheets %}
<style>
    body { margin: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f5f5f5; }
    .error-container {
        max-width: 600px; margin: 120px auto; text-align: center; padding: 40px;
        background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.1);
    }
    .error-container h1 { color: #c62828; font-size: 24px; margin-bottom: 16px; }
    .error-container p { color: #555; font-size: 16px; line-height: 1.6; }
    .error-container a { display: inline-block; margin-top: 24px; color: #1a237e; text-decoration: none; font-weight: 600; }
    .error-container a:hover { text-decoration: underline; }
</style>
{% endblock %}

{% block body %}
<div class="error-container">
    <h1>Ocorreu um erro</h1>
    <p>{{ message }}</p>
    <a href="/">← Voltar ao início</a>
</div>
{% endblock %}
